{
  "name": "stelar-time-real",
  "version": "3.2.0",
  "description": "Zero-dependency production real-time library. Custom binary TCP + manual WebSocket. No ws package. Rate limiting (custom/per-event/per-client), hooks, custom IP tracker, custom health check, runtime config, rooms, ACKs, middleware, TLS/SSL.",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "websocket",
    "real-time",
    "realtime",
    "stelar",
    "chat",
    "webserver",
    "tcp",
    "binary-protocol",
    "zero-dependency",
    "custom-protocol",
    "production",
    "rate-limiting",
    "health-check"
  ],
  "author": "Stelar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/foxytp/stelar-time-real"
  },
  "bugs": {
    "url": "https://github.com/foxytp/stelar-time-real/issues"
  },
  "homepage": "https://github.com/foxytp/stelar-time-real#readme",
  "exports": {
    ".": "./src/index.js",
    "./client": "./src/client.js",
    "./client.js": "./src/client.js"
  },
  "files": [
    "src"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.3.0"
  }
}
